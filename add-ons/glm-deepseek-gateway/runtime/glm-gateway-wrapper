#!/usr/bin/env python3
from __future__ import annotations

import os
import sys

from glm_gateway_common import claude_environment, ensure_gateway, read_config


def main() -> int:
    if len(sys.argv) < 2:
        print("NG: Claude Code did not provide its bundled executable.", file=sys.stderr)
        return 64
    config = read_config()
    workspace = str(config.get("workspace") or "")
    if not workspace or not os.path.isdir(workspace):
        print("NG: configured workspace is missing", file=sys.stderr)
        return 1
    ensure_gateway(config)
    os.chdir(workspace)
    os.execvpe(sys.argv[1], sys.argv[1:], claude_environment(config))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

