class OfficeError(Exception):
    pass


def executable(*names: str) -> str | None:
    for name in names:
        found = shutil.which(name)
        if found:
            return found
    for candidate in (
        "/Applications/LibreOffice.app/Contents/MacOS/soffice",
        "/Applications/LibreOffice.app/Contents/MacOS/libreoffice",
    ):
        if Path(candidate).is_file():
            return candidate
    return None


def cmd_status(args: argparse.Namespace) -> int:
    try:
        import odf  # noqa: F401
        odfpy = True
    except ImportError:
        odfpy = False
    try:
        import PIL  # noqa: F401
        pillow = True
    except ImportError:
        pillow = False
    result = {
        "odfpy": odfpy,
        "pillow": pillow,
        "libreoffice": executable("soffice", "libreoffice"),
        "tesseract": executable("tesseract"),
        "pdftotext": executable("pdftotext"),
        "pdfinfo": executable("pdfinfo"),
        "pdftoppm": executable("pdftoppm"),
        "noto_sans_cjk_jp_registered": font_available("Noto Sans CJK JP"),
    }
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0 if odfpy and pillow else 1


def font_available(family: str) -> bool:
    matcher = executable("fc-match")
    if matcher:
        result = subprocess.run([matcher, "-f", "%{family}\n", family], capture_output=True, text=True)
        return result.returncode == 0 and family.casefold() in result.stdout.casefold()
    roots = [Path.home() / "Library" / "Fonts", Path("/Library/Fonts"), Path("/usr/share/fonts")]
    needle = re.sub(r"[^a-z0-9]", "", family.casefold())
    for root in roots:
        if not root.is_dir():
            continue
        for path in root.rglob("*"):
            if path.is_file() and needle in re.sub(r"[^a-z0-9]", "", path.name.casefold()):
                return True
    return False


def require_odfpy():
    try:
        from odf import style, table, text
        from odf.opendocument import OpenDocumentText
    except ImportError as error:
        raise OfficeError("odfpy is required. Run: python3 -m pip install --user odfpy") from error
    return style, table, text, OpenDocumentText


def require_presentation_dependencies():
    try:
        from odf import draw, style, text
        from odf.opendocument import OpenDocumentPresentation
        from PIL import Image, ImageOps, UnidentifiedImageError
    except ImportError as error:
        raise OfficeError(
            "ODP photo slides require odfpy and Pillow. "
            "Run: python3 -m pip install --user odfpy Pillow"
        ) from error
    return draw, style, text, OpenDocumentPresentation, Image, ImageOps, UnidentifiedImageError


def require_drawing_dependencies():
    try:
        from odf import draw, style, text
        from odf.opendocument import OpenDocumentDrawing
    except ImportError as error:
        raise OfficeError(
            "ODG receipt sheets require odfpy. "
            "Run: python3 -m pip install --user odfpy"
        ) from error
    return draw, style, text, OpenDocumentDrawing


def add_text(parent, text_module, value: str, style_name=None):
    parent.addElement(text_module.P(text=value, stylename=style_name))


def document_text_properties(style_module, font_name: str, size: str, weight: str):
    return style_module.TextProperties(
        fontname=font_name,
        fontnameasian=font_name,
        fontnamecomplex=font_name,
        fontsize=size,
        fontsizeasian=size,
        fontsizecomplex=size,
        fontweight=weight,
        fontweightasian=weight,
        fontweightcomplex=weight,
    )


def display_width(value: object) -> int:
    return sum(
        2 if unicodedata.east_asian_width(character) in {"W", "F", "A"} else 1
        for character in str(value)
    )


def table_column_widths(rows: list[list[object]], total_width_mm: float = 174.0) -> list[float]:
    column_count = max(len(row) for row in rows)
    natural = [4] * column_count
    for row in rows:
        for index, value in enumerate(row):
            natural[index] = max(natural[index], min(display_width(value), 48))

    if column_count == 2 and natural[0] * 2 <= natural[1]:
        shares = [0.28, 0.72]
    else:
        minimum_share = min(0.16, 0.8 / column_count)
        remaining = 1.0 - minimum_share * column_count
        natural_total = sum(natural)
        shares = [minimum_share + remaining * value / natural_total for value in natural]
    return [round(total_width_mm * share, 2) for share in shares]


def cmd_create_odt(args: argparse.Namespace) -> int:
    style, table, text, OpenDocumentText = require_odfpy()
    spec = json.loads(Path(args.input).read_text(encoding="utf-8"))
    output = Path(args.output).expanduser().resolve()
    output.parent.mkdir(parents=True, exist_ok=True)
    doc = OpenDocumentText()
    font_name = "Noto Sans CJK JP" if args.profile == "japanese" else "Arial"
    doc.fontfacedecls.addElement(style.FontFace(
        name=font_name,
        fontfamily=font_name,
        fontfamilygeneric="swiss",
        fontpitch="variable",
    ))

    page = style.PageLayout(name="A4Page")
    page.addElement(style.PageLayoutProperties(
        pagewidth="210mm", pageheight="297mm", printorientation="portrait",
        margintop="20mm", marginright="18mm", marginbottom="18mm", marginleft="18mm"))
    doc.automaticstyles.addElement(page)
    master = style.MasterPage(name="A4", pagelayoutname=page)
    doc.masterstyles.addElement(master)

    default = style.Style(name="Body", family="paragraph")
    default.addElement(document_text_properties(style, font_name, "10.5pt", "normal"))
    default.addElement(style.ParagraphProperties(lineheight="155%", marginbottom="3mm"))
    doc.styles.addElement(default)
    title = style.Style(name="Title", family="paragraph", parentstylename=default, masterpagename=master)
    title.addElement(document_text_properties(style, font_name, "18pt", "bold"))
    title.addElement(style.ParagraphProperties(marginbottom="4mm", paddingbottom="2mm", borderbottom="0.8pt solid #222222"))
    doc.styles.addElement(title)
    heading1 = style.Style(name="Heading1", family="paragraph", parentstylename=default)
    heading1.addElement(document_text_properties(style, font_name, "13pt", "bold"))
    heading1.addElement(style.ParagraphProperties(
        margintop="5mm", marginbottom="2.5mm", paddingbottom="1.2mm",
        borderbottom="0.5pt solid #777777"))
    doc.styles.addElement(heading1)
    heading2 = style.Style(name="Heading2", family="paragraph", parentstylename=default)
    heading2.addElement(document_text_properties(style, font_name, "11.5pt", "bold"))
    heading2.addElement(style.ParagraphProperties(margintop="3.5mm", marginbottom="1.5mm"))
    doc.styles.addElement(heading2)
    heading3 = style.Style(name="Heading3", family="paragraph", parentstylename=default)
    heading3.addElement(document_text_properties(style, font_name, "10.5pt", "bold"))
    heading3.addElement(style.ParagraphProperties(margintop="2.5mm", marginbottom="1mm"))
    doc.styles.addElement(heading3)
    headings = {1: heading1, 2: heading2, 3: heading3}
    table_text = style.Style(name="TableText", family="paragraph", parentstylename=default)
    table_text.addElement(document_text_properties(style, font_name, "10pt", "normal"))
    table_text.addElement(style.ParagraphProperties(lineheight="140%", marginbottom="0mm"))
    doc.styles.addElement(table_text)
    table_head_text = style.Style(name="TableHeadText", family="paragraph", parentstylename=table_text)
    table_head_text.addElement(document_text_properties(style, font_name, "10pt", "bold"))
    doc.styles.addElement(table_head_text)
    cell = style.Style(name="TableCell", family="table-cell")
    cell.addElement(style.TableCellProperties(border="0.5pt solid #888888", padding="2mm", verticalalign="middle"))
    doc.automaticstyles.addElement(cell)
    cell_head = style.Style(name="TableHead", family="table-cell")
    cell_head.addElement(style.TableCellProperties(
        backgroundcolor="#F2F2F2", border="0.5pt solid #888888",
        padding="2mm", verticalalign="middle"))
    doc.automaticstyles.addElement(cell_head)

    add_text(doc.text, text, str(spec.get("title", "Untitled")), title)
    for block_index, block in enumerate(spec.get("blocks", []), start=1):
        kind = block.get("type")
        if kind == "heading":
            try:
                level = int(block.get("level", 2))
            except (TypeError, ValueError):
                level = 2
            add_text(doc.text, text, str(block.get("text", "")), headings.get(level, heading3))
        elif kind == "paragraph":
            add_text(doc.text, text, str(block.get("text", "")), default)
        elif kind == "list":
            listing = text.List()
            for item in block.get("items", []):
                entry = text.ListItem()
                add_text(entry, text, str(item), default)
                listing.addElement(entry)
            doc.text.addElement(listing)
        elif kind == "table":
            rows = block.get("rows", [])
            if not rows:
                continue
            grid = table.Table(name="Table")
            for column_index, width in enumerate(table_column_widths(rows), start=1):
                column_style = style.Style(
                    name=f"TableColumn{block_index}_{column_index}", family="table-column")
                column_style.addElement(style.TableColumnProperties(columnwidth=f"{width}mm"))
                doc.automaticstyles.addElement(column_style)
                grid.addElement(table.TableColumn(stylename=column_style))
            for row_index, values in enumerate(rows):
                row = table.TableRow()
                for value in values:
                    target = table.TableCell(stylename=cell_head if row_index == 0 else cell)
                    add_text(target, text, str(value), table_head_text if row_index == 0 else table_text)
                    row.addElement(target)
                grid.addElement(row)
            doc.text.addElement(grid)
        else:
            raise OfficeError(f"Unsupported block type: {kind}")
    doc.save(str(output))
    print(output)
    return 0


SLIDE_WIDTH = 13.333333
SLIDE_HEIGHT = 7.5
SLIDE_LEFT = 0.4375
SLIDE_RIGHT = 0.4375
SLIDE_PHOTO_TOP = 0.94
SLIDE_BOTTOM = 0.38
SLIDE_GAP = 0.14


def inch(value: float) -> str:
    return f"{value:.4f}in"


def mm(value: float) -> str:
    return f"{value:.3f}mm"


RECEIPT_PAGE_WIDTH_MM = 297.0
RECEIPT_PAGE_HEIGHT_MM = 210.0
RECEIPT_WIDTH_MM = 148.5
RECEIPT_HEIGHT_MM = 70.0


def add_drawing_text(page, draw, text, frame_style, paragraph_style, value, *, name, x, y, width, height):
    frame = draw.Frame(
        name=name,
        stylename=frame_style,
        x=mm(x), y=mm(y), width=mm(width), height=mm(height),
    )
    box = draw.TextBox()
    box.addElement(text.P(text=value, stylename=paragraph_style))
    frame.addElement(box)
    page.addElement(frame)


def add_drawing_lines(page, draw, text, frame_style, paragraph_style, values, *, name, x, y, width, height):
    frame = draw.Frame(
        name=name,
        stylename=frame_style,
        x=mm(x), y=mm(y), width=mm(width), height=mm(height),
    )
    box = draw.TextBox()
    for value in values:
        box.addElement(text.P(text=value, stylename=paragraph_style))
    frame.addElement(box)
    page.addElement(frame)


def receipt_value(item: dict, key: str, blank: str, prefix: str = "") -> str:
    value = str(item.get(key, "")).strip()
    return f"{prefix}{value}" if value else blank


def cmd_create_receipts(args: argparse.Namespace) -> int:
    draw, style, text, OpenDocumentDrawing = require_drawing_dependencies()
    spec_path = Path(args.input).expanduser().resolve()
    spec = json.loads(spec_path.read_text(encoding="utf-8"))
    output = Path(args.output).expanduser().resolve()
    if output.suffix.lower() != ".odg":
        raise OfficeError("Six-up receipt output must use the .odg extension.")
    output.parent.mkdir(parents=True, exist_ok=True)

    issuer = spec.get("issuer", {})
    if not isinstance(issuer, dict):
        raise OfficeError("Receipt issuer must be an object.")
    receipts = spec.get("receipts", [])
    if not isinstance(receipts, list) or len(receipts) > 6:
        raise OfficeError("Receipt specification supports at most six receipt entries.")
    receipts = [item if isinstance(item, dict) else {} for item in receipts]
    receipts.extend({} for _ in range(6 - len(receipts)))

    doc = OpenDocumentDrawing()
    font_name = "Noto Sans CJK JP" if args.profile == "japanese" else "Arial"
    bold_face_name = f"{font_name} Bold"
    quoted_font_family = f"'{font_name}'"
    for face_name, weight in ((font_name, "normal"), (bold_face_name, "bold")):
        attributes = {
            "name": face_name,
            "fontfamily": quoted_font_family,
            "fontfamilygeneric": "swiss",
            "fontpitch": "variable",
        }
        if weight == "bold":
            attributes.update(fontweight="bold", fontadornments="Bold")
        doc.fontfacedecls.addElement(style.FontFace(**attributes))

    page_layout = style.PageLayout(name="ReceiptSheetPage")
    page_layout.addElement(style.PageLayoutProperties(
        pagewidth=mm(RECEIPT_PAGE_WIDTH_MM),
        pageheight=mm(RECEIPT_PAGE_HEIGHT_MM),
        printorientation="landscape",
        margintop="0mm", marginright="0mm", marginbottom="0mm", marginleft="0mm",
    ))
    doc.automaticstyles.addElement(page_layout)
    master = style.MasterPage(name="ReceiptSheetMaster", pagelayoutname=page_layout)
    doc.masterstyles.addElement(master)

    page_style = style.Style(name="ReceiptSheetBackground", family="drawing-page")
    page_style.addElement(style.DrawingPageProperties(fill="solid", fillcolor="#FFFFFF"))
    doc.automaticstyles.addElement(page_style)
    text_frame = style.Style(name="ReceiptTextFrame", family="graphic")
    text_frame.addElement(style.GraphicProperties(fill="none", stroke="none"))
    doc.automaticstyles.addElement(text_frame)
    cut_style = style.Style(name="ReceiptCutLine", family="graphic")
    cut_style.addElement(style.GraphicProperties(
        stroke="solid", strokecolor="#8A8A8A", strokewidth="0.45pt",
    ))
    doc.automaticstyles.addElement(cut_style)
    field_style = style.Style(name="ReceiptFieldLine", family="graphic")
    field_style.addElement(style.GraphicProperties(
        stroke="solid", strokecolor="#4A4A4A", strokewidth="0.55pt",
    ))
    doc.automaticstyles.addElement(field_style)
    amount_box_style = style.Style(name="ReceiptAmountBox", family="graphic")
    amount_box_style.addElement(style.GraphicProperties(
        fill="none", stroke="solid", strokecolor="#222222", strokewidth="0.75pt",
    ))
    doc.automaticstyles.addElement(amount_box_style)

    def paragraph_style(name: str, size: str, weight: str, align: str):
        target = style.Style(name=name, family="paragraph")
        target.addElement(style.ParagraphProperties(
            textalign=align, margintop="0mm", marginbottom="0mm", lineheight="115%",
        ))
        target.addElement(style.TextProperties(
            fontname=bold_face_name if weight == "bold" else font_name,
            fontnameasian=bold_face_name if weight == "bold" else font_name,
            fontfamily=quoted_font_family, fontfamilyasian=quoted_font_family,
            fontstylename="Bold" if weight == "bold" else "Regular",
            fontstylenameasian="Bold" if weight == "bold" else "Regular",
            fontsize=size, fontsizeasian=size,
            fontweight=weight, fontweightasian=weight,
            language="ja" if args.profile == "japanese" else "en",
            country="JP" if args.profile == "japanese" else "US",
            languageasian="ja" if args.profile == "japanese" else "en",
            countryasian="JP" if args.profile == "japanese" else "US",
            color="#171717",
        ))
        doc.automaticstyles.addElement(target)
        return target

    title_style = paragraph_style("ReceiptTitle", "14pt", "bold", "left")
    date_style = paragraph_style("ReceiptDate", "7.5pt", "normal", "right")
    recipient_style = paragraph_style("ReceiptRecipient", "9.5pt", "normal", "left")
    amount_style = paragraph_style("ReceiptAmount", "12pt", "bold", "left")
    body_style = paragraph_style("ReceiptBody", "8pt", "normal", "left")
    issuer_style = paragraph_style("ReceiptIssuer", "7pt", "normal", "right")

    page = draw.Page(name="receipt-sheet", masterpagename=master, stylename=page_style)
    page.addElement(draw.Line(
        name="cut-vertical", stylename=cut_style,
        x1=mm(RECEIPT_WIDTH_MM), y1="0mm",
        x2=mm(RECEIPT_WIDTH_MM), y2=mm(RECEIPT_PAGE_HEIGHT_MM),
    ))
    for row, y in enumerate((RECEIPT_HEIGHT_MM, RECEIPT_HEIGHT_MM * 2), start=1):
        page.addElement(draw.Line(
            name=f"cut-horizontal-{row}", stylename=cut_style,
            x1="0mm", y1=mm(y), x2=mm(RECEIPT_PAGE_WIDTH_MM), y2=mm(y),
        ))

    issuer_lines = [str(issuer.get("name", "")).strip() or "発行者名"]
    issuer_lines.extend(
        value for value in (
            str(issuer.get("address", "")).strip(),
            str(issuer.get("contact", "")).strip(),
        ) if value
    )
    for index, item in enumerate(receipts, start=1):
        column = (index - 1) % 2
        row = (index - 1) // 2
        origin_x = column * RECEIPT_WIDTH_MM
        origin_y = row * RECEIPT_HEIGHT_MM
        left = origin_x + 5.0
        width = RECEIPT_WIDTH_MM - 10.0

        add_drawing_text(
            page, draw, text, text_frame, title_style, "領収書",
            name=f"title-{index}", x=left, y=origin_y + 3.2, width=48, height=8,
        )
        date_value = receipt_value(
            item, "date", "発行年月日：　　　年　　月　　日", "発行年月日：",
        )
        add_drawing_text(
            page, draw, text, text_frame, date_style, date_value,
            name=f"date-{index}", x=origin_x + 77, y=origin_y + 4.1, width=66.5, height=6,
        )

        recipient = str(item.get("recipient", "")).strip()
        recipient_text = f"{recipient}　様" if recipient else "様"
        add_drawing_text(
            page, draw, text, text_frame, recipient_style, recipient_text,
            name=f"recipient-{index}", x=left, y=origin_y + 13.5, width=width, height=7,
        )
        page.addElement(draw.Line(
            name=f"recipient-line-{index}", stylename=field_style,
            x1=mm(left), y1=mm(origin_y + 21.0),
            x2=mm(origin_x + 117.0), y2=mm(origin_y + 21.0),
        ))

        page.addElement(draw.Rect(
            name=f"amount-box-{index}", stylename=amount_box_style,
            x=mm(left), y=mm(origin_y + 24.0), width=mm(width), height="11mm",
        ))
        amount = str(item.get("amount", "")).strip()
        amount_text = f"金額　￥{amount}" if amount else "金額　￥"
        add_drawing_text(
            page, draw, text, text_frame, amount_style, amount_text,
            name=f"amount-{index}", x=left + 3, y=origin_y + 25.5, width=width - 6, height=7,
        )

        description = str(item.get("description", "")).strip()
        description_text = f"但し　{description}" if description else "但し"
        add_drawing_text(
            page, draw, text, text_frame, body_style, description_text,
            name=f"description-{index}", x=left, y=origin_y + 38.2, width=width, height=6,
        )
        if not description:
            page.addElement(draw.Line(
                name=f"description-line-{index}", stylename=field_style,
                x1=mm(left + 12), y1=mm(origin_y + 44.7),
                x2=mm(origin_x + RECEIPT_WIDTH_MM - 5), y2=mm(origin_y + 44.7),
            ))

        add_drawing_text(
            page, draw, text, text_frame, body_style, "上記正に領収いたしました。",
            name=f"statement-{index}", x=left, y=origin_y + 49.0, width=68, height=7,
        )
        add_drawing_lines(
            page, draw, text, text_frame, issuer_style, issuer_lines,
            name=f"issuer-{index}", x=origin_x + 76, y=origin_y + 48.0, width=67.5, height=17,
        )

    doc.drawing.addElement(page)
    doc.save(str(output))
    print(output)
    return 0


def photo_orientation(width: int, height: int) -> str:
    return "landscape" if width >= height else "portrait"


def convert_phone_photo(source: Path, destination: Path) -> Path | None:
    converter = executable("magick", "convert")
    if converter:
        command = [converter]
        if Path(converter).name == "magick":
            command.append(str(source))
        else:
            command.append(str(source))
        command.extend(["-auto-orient", str(destination)])
        result = subprocess.run(command, capture_output=True, text=True)
        if result.returncode == 0 and destination.is_file():
            return destination
    sips = executable("sips")
    if sips:
        result = subprocess.run(
            [sips, "-s", "format", "jpeg", str(source), "--out", str(destination)],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and destination.is_file():
            return destination
    return None


def normalized_photo(source: Path, work: Path, Image, ImageOps, UnidentifiedImageError):
    if not source.is_file():
        raise OfficeError(f"Photo does not exist: {source}")
    candidate = source
    try:
        image = Image.open(candidate)
        image.load()
    except (UnidentifiedImageError, OSError):
        converted = convert_phone_photo(source, work / f"{source.stem}.jpg")
        if not converted:
            raise OfficeError(
                f"Unsupported photo format: {source}. Install an HEIC-capable ImageMagick "
                "or convert the photo to JPEG/PNG."
            )
        candidate = converted
        image = Image.open(candidate)
        image.load()
    image = ImageOps.exif_transpose(image)
    if image.mode != "RGB":
        background = Image.new("RGB", image.size, "white")
        if "A" in image.getbands():
            background.paste(image, mask=image.getchannel("A"))
        else:
            background.paste(image)
        image = background
    payload = io.BytesIO()
    image.save(payload, format="JPEG", quality=92, optimize=True)
    return payload.getvalue(), image.width, image.height


def resolved_photo_path(spec_path: Path, value: str) -> Path:
    path = Path(value).expanduser()
    return path.resolve() if path.is_absolute() else (spec_path.parent / path).resolve()


def inferred_slide_layout(orientations: list[str]) -> str:
    if orientations == ["landscape"]:
        return "landscape-single"
    if orientations == ["portrait"]:
        return "portrait-single"
    if orientations == ["landscape", "landscape"]:
        return "landscape-landscape"
    if orientations == ["portrait", "landscape"]:
        return "portrait-landscape"
    if orientations == ["landscape", "portrait"]:
        return "landscape-portrait"
    if orientations == ["portrait", "portrait"]:
        return "portrait-portrait"
    raise OfficeError("Photo slides support one or two photos per slide.")


def layout_cells(layout: str) -> list[tuple[float, float, float, float]]:
    width = SLIDE_WIDTH - SLIDE_LEFT - SLIDE_RIGHT
    height = SLIDE_HEIGHT - SLIDE_PHOTO_TOP - SLIDE_BOTTOM
    if layout in ("landscape-single", "portrait-single"):
        return [(SLIDE_LEFT, SLIDE_PHOTO_TOP, width, height)]
    usable = width - SLIDE_GAP
    if layout in ("landscape-landscape", "portrait-portrait"):
        left_width = usable / 2
    elif layout == "portrait-landscape":
        left_width = usable * 0.36
    elif layout == "landscape-portrait":
        left_width = usable * 0.64
    else:
        raise OfficeError(f"Unsupported photo-slide layout: {layout}")
    right_width = usable - left_width
    return [
        (SLIDE_LEFT, SLIDE_PHOTO_TOP, left_width, height),
        (SLIDE_LEFT + left_width + SLIDE_GAP, SLIDE_PHOTO_TOP, right_width, height),
    ]


def contained_box(cell, image_width: int, image_height: int):
    x, y, width, height = cell
    scale = min(width / image_width, height / image_height)
    rendered_width = image_width * scale
    rendered_height = image_height * scale
    return (
        x + (width - rendered_width) / 2,
        y + (height - rendered_height) / 2,
        rendered_width,
        rendered_height,
    )


def add_slide_text(page, draw, text, frame_style, paragraph_style, value, *, name, x, y, width, height):
    frame = draw.Frame(
        name=name,
        stylename=frame_style,
        x=inch(x), y=inch(y), width=inch(width), height=inch(height),
    )
    box = draw.TextBox()
    box.addElement(text.P(text=value, stylename=paragraph_style))
    frame.addElement(box)
    page.addElement(frame)


