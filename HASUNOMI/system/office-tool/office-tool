                frame.addElement(draw.Image(href=href, type="simple", show="embed", actuate="onLoad"))
                page.addElement(frame)
            doc.presentation.addElement(page)
    doc.save(str(output))
    print(output)
    return 0


def office_content(path: Path) -> str:
    with zipfile.ZipFile(path) as archive:
        return archive.read("content.xml").decode("utf-8", errors="replace")


def pdf_inspection(path: Path) -> tuple[int | None, list[int], list[str]]:
    failures: list[str] = []
    pdfinfo = executable("pdfinfo")
    pdftotext = executable("pdftotext")
    if not pdfinfo:
        return None, [], ["pdfinfo unavailable"]
    result = subprocess.run([pdfinfo, str(path)], capture_output=True, text=True)
    if result.returncode:
        return None, [], ["pdfinfo could not read the PDF"]
    match = re.search(r"^Pages:\s+(\d+)", result.stdout, re.MULTILINE)
    pages = int(match.group(1)) if match else None
    if pages is None:
        failures.append("page count unavailable")
    blank_pages: list[int] = []
    if pages and pdftotext:
        with tempfile.TemporaryDirectory(prefix="office-verify-") as tmp:
            for page in range(1, pages + 1):
                target = Path(tmp) / f"page-{page}.txt"
                extracted = subprocess.run(
                    [pdftotext, "-f", str(page), "-l", str(page), str(path), str(target)],
                    capture_output=True,
                    text=True,
                )
                if extracted.returncode == 0 and not target.read_text(encoding="utf-8", errors="replace").strip():
                    blank_pages.append(page)
    return pages, blank_pages, failures


def pdf_fonts(path: Path) -> list[dict[str, str]]:
    inspector = executable("pdffonts")
    if not inspector:
        raise OfficeError("pdffonts is required for embedded-font verification.")
    result = subprocess.run([inspector, str(path)], capture_output=True, text=True)
    if result.returncode:
        raise OfficeError((result.stderr or result.stdout or "pdffonts failed").strip())
    fonts: list[dict[str, str]] = []
    for line in result.stdout.splitlines()[2:]:
        fields = line.split()
        if len(fields) < 8:
            continue
        fonts.append({
            "name": fields[0],
            "type": " ".join(fields[1:-6]),
            "embedded": fields[-5],
            "subset": fields[-4],
        })
    return fonts


def normalized_font_name(value: str) -> str:
    value = re.sub(r"^[A-Z]{6}\+", "", value)
    return re.sub(r"[^a-z0-9]", "", value.casefold())


def expected_font_failures(
    fonts: list[dict[str, str]], family: str, require_bold: bool,
) -> list[str]:
    expected = normalized_font_name(family)
    matching = [font for font in fonts if expected in normalized_font_name(font["name"])]
    failures: list[str] = []
    if not matching:
        return [f"rendered PDF does not use {family}"]
    if any(font["embedded"].casefold() != "yes" for font in matching):
        failures.append(f"rendered PDF does not embed every used {family} font")
    if require_bold and not any("bold" in normalized_font_name(font["name"]) for font in matching):
        failures.append(f"rendered PDF does not use the Bold face of {family}")
    return failures


def render_office_pdf(path: Path, destination: Path) -> Path:
    office = executable("soffice", "libreoffice")
    if not office:
        raise OfficeError("LibreOffice is required to render this document for verification.")
    result = subprocess.run(
        [office, "--headless", "--convert-to", "pdf", "--outdir", str(destination), str(path)],
        capture_output=True,
        text=True,
    )
    rendered = destination / f"{path.stem}.pdf"
    if result.returncode or not rendered.is_file():
        raise OfficeError((result.stderr or result.stdout or "LibreOffice conversion failed").strip())
    return rendered


def cmd_verify(args: argparse.Namespace) -> int:
    path = Path(args.file).expanduser().resolve()
    failures: list[str] = []
    pages = None
    blank_pages: list[int] = []
    if not path.is_file():
        failures.append("file does not exist")
    elif path.suffix.lower() == ".odt":
        try:
            with zipfile.ZipFile(path) as archive:
                names = set(archive.namelist())
            if "content.xml" not in names or "styles.xml" not in names:
                failures.append("invalid ODT package")
            if "office:text" not in office_content(path):
                failures.append("ODT has no text body")
            with tempfile.TemporaryDirectory(prefix="office-render-") as tmp:
                rendered = render_office_pdf(path, Path(tmp))
                pages, blank_pages, render_failures = pdf_inspection(rendered)
                failures.extend(render_failures)
                if args.expect_font:
                    failures.extend(expected_font_failures(
                        pdf_fonts(rendered), args.expect_font, args.require_bold,
                    ))
        except zipfile.BadZipFile:
            failures.append("invalid ZIP container")
        except OfficeError as error:
            failures.append(str(error))
    elif path.suffix.lower() == ".odp":
        try:
            with zipfile.ZipFile(path) as archive:
                names = set(archive.namelist())
            if "content.xml" not in names or "styles.xml" not in names:
                failures.append("invalid ODP package")
            content = office_content(path)
            slide_count = len(re.findall(r"<draw:page\b", content))
            image_count = len(re.findall(r"<draw:image\b", content))
            if slide_count == 0:
                failures.append("ODP has no slides")
            if image_count == 0:
                failures.append("ODP has no photos")
            with tempfile.TemporaryDirectory(prefix="office-render-") as tmp:
                rendered = render_office_pdf(path, Path(tmp))
                pages, blank_pages, render_failures = pdf_inspection(rendered)
                failures.extend(render_failures)
                if pages is not None and pages != slide_count:
                    failures.append(f"rendered page count {pages} does not match slide count {slide_count}")
                if args.expect_font:
                    failures.extend(expected_font_failures(
                        pdf_fonts(rendered), args.expect_font, args.require_bold,
                    ))
        except zipfile.BadZipFile:
            failures.append("invalid ZIP container")
        except OfficeError as error:
            failures.append(str(error))
    elif path.suffix.lower() == ".odg":
        try:
            with zipfile.ZipFile(path) as archive:
                names = set(archive.namelist())
            if "content.xml" not in names or "styles.xml" not in names:
                failures.append("invalid ODG package")
            content = office_content(path)
            if "office:drawing" not in content:
                failures.append("ODG has no drawing body")
            if len(re.findall(r"draw:name=\"amount-box-", content)) != 6:
                failures.append("ODG does not contain six receipt amount boxes")
            with tempfile.TemporaryDirectory(prefix="office-render-") as tmp:
                rendered = render_office_pdf(path, Path(tmp))
                pages, blank_pages, render_failures = pdf_inspection(rendered)
                failures.extend(render_failures)
                if pages is not None and pages != 1:
                    failures.append(f"rendered receipt sheet has {pages} pages instead of 1")
                if args.expect_font:
                    failures.extend(expected_font_failures(
                        pdf_fonts(rendered), args.expect_font, args.require_bold,
                    ))
        except zipfile.BadZipFile:
            failures.append("invalid ZIP container")
        except OfficeError as error:
            failures.append(str(error))
    elif path.suffix.lower() == ".pdf":
        pages, blank_pages, pdf_failures = pdf_inspection(path)
        failures.extend(pdf_failures)
        if args.expect_font:
            failures.extend(expected_font_failures(
                pdf_fonts(path), args.expect_font, args.require_bold,
            ))
    else:
        failures.append("verification supports ODT, ODP, ODG, and PDF")
    if blank_pages and not args.allow_blank_pages:
        failures.append("blank pages: " + ", ".join(map(str, blank_pages)))
    print(json.dumps({
        "file": str(path), "ok": not failures, "failures": failures,
        "pages": pages, "blank_pages": blank_pages,
    }, ensure_ascii=False, indent=2))
    return 1 if failures else 0


def cmd_font_check(args: argparse.Namespace) -> int:
    _, _, _, _, Image, _, _ = require_presentation_dependencies()
    with tempfile.TemporaryDirectory(prefix="office-font-check-") as tmp:
        work = Path(tmp)
        image = work / "sample.jpg"
        Image.new("RGB", (640, 360), "#D9D9D9").save(image, format="JPEG")
        spec = work / "spec.json"
