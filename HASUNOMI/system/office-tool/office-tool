        return 1 if failures else 0


def cmd_convert(args: argparse.Namespace) -> int:
    source = Path(args.input).expanduser().resolve()
    output = Path(args.output).expanduser().resolve()
    if not source.is_file():
        raise OfficeError(f"Input does not exist: {source}")
    office = executable("soffice", "libreoffice")
    if not office:
        raise OfficeError("LibreOffice is unavailable.")
    output.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory(prefix="office-convert-") as tmp:
        result = subprocess.run(
            [office, "--headless", "--convert-to", args.format, "--outdir", tmp, str(source)],
            capture_output=True,
            text=True,
        )
        generated = Path(tmp) / f"{source.stem}.{args.format}"
        if result.returncode or not generated.is_file():
            raise OfficeError((result.stderr or result.stdout or "LibreOffice conversion failed").strip())
        shutil.copy2(generated, output)
    print(output)
    return 0


def cmd_ocr(args: argparse.Namespace) -> int:
    tesseract = executable("tesseract")
    if not tesseract:
        raise OfficeError("Tesseract OCR is unavailable. Install it or configure another OCR backend.")
    source = Path(args.input).expanduser().resolve()
    output = Path(args.output).expanduser().resolve()
    output.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory(prefix="hasunomi-ocr-") as tmp:
        work = Path(tmp)
        if source.suffix.lower() == ".pdf":
            pdftoppm = executable("pdftoppm")
            if not pdftoppm:
                raise OfficeError("pdftoppm is required for PDF OCR.")
            rendered = work / "page"
            result = subprocess.run([pdftoppm, "-png", "-r", "300", str(source), str(rendered)], capture_output=True, text=True)
            if result.returncode:
                raise OfficeError((result.stderr or result.stdout).strip())
            pages = sorted(work.glob("page-*.png"))
        else:
            pages = [source]
        if not pages:
            raise OfficeError("No OCR pages were produced.")
        texts: list[str] = []
        preprocessing = "not-available"
        image_tool = executable("magick", "convert")
        for index, page in enumerate(pages, start=1):
            prepared = page
            if image_tool:
                candidate = work / f"prepared-{index}.png"
                command = [image_tool]
                if Path(image_tool).name == "magick":
                    command.append(str(page))
                else:
                    command.append(str(page))
                command.extend(["-colorspace", "Gray", "-auto-level", "-deskew", "40%", "-sharpen", "0x1", str(candidate)])
                converted = subprocess.run(command, capture_output=True, text=True)
                if converted.returncode == 0 and candidate.is_file():
                    prepared = candidate
                    preprocessing = "grayscale-auto-level-deskew-sharpen"
                else:
                    preprocessing = "failed-used-original"
            base = work / f"ocr-{index}"
            result = subprocess.run([tesseract, str(prepared), str(base), "-l", args.lang], capture_output=True, text=True)
            if result.returncode:
                raise OfficeError((result.stderr or result.stdout).strip())
            texts.append(base.with_suffix(".txt").read_text(encoding="utf-8", errors="replace").strip())
        extracted = "\n\n".join(texts)
    output.write_text(
        f"---\nsource: {source.name}\nlanguage: {args.language_name}\n---\n\n# Extracted Text\n\n{extracted}\n",
        encoding="utf-8",
    )
    print(f"engine=tesseract preprocessing={preprocessing} pages={len(pages)}", file=sys.stderr)
    print(output)
    return 0


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(prog="office-tool")
    sub = result.add_subparsers(dest="command", required=True)
    sub.add_parser("status").set_defaults(func=cmd_status)
    create = sub.add_parser("create-odt")
    create.add_argument("input")
    create.add_argument("output")
    create.add_argument("--profile", choices=("default", "japanese"), default="default")
    create.set_defaults(func=cmd_create_odt)
    create_slides = sub.add_parser("create-odp")
    create_slides.add_argument("input")
    create_slides.add_argument("output")
    create_slides.add_argument("--profile", choices=("default", "japanese"), default="default")
    create_slides.set_defaults(func=cmd_create_odp)
    create_receipts = sub.add_parser("create-receipts")
    create_receipts.add_argument("input")
    create_receipts.add_argument("output")
    create_receipts.add_argument("--profile", choices=("default", "japanese"), default="japanese")
    create_receipts.set_defaults(func=cmd_create_receipts)
    verify = sub.add_parser("verify")
    verify.add_argument("file")
    verify.add_argument("--allow-blank-pages", action="store_true")
    verify.add_argument("--expect-font")
    verify.add_argument("--require-bold", action="store_true")
    verify.set_defaults(func=cmd_verify)
    font_check = sub.add_parser("font-check")
    font_check.add_argument("--profile", choices=("japanese",), default="japanese")
    font_check.set_defaults(func=cmd_font_check)
    convert = sub.add_parser("convert")
    convert.add_argument("input")
    convert.add_argument("output")
    convert.add_argument("--format", choices=("pdf", "odt", "docx"), required=True)
    convert.set_defaults(func=cmd_convert)
    ocr = sub.add_parser("ocr")
    ocr.add_argument("input")
    ocr.add_argument("output")
    ocr.add_argument("--lang", default="eng")
    ocr.add_argument("--language-name", default="English")
    ocr.set_defaults(func=cmd_ocr)
    return result


if __name__ == "__main__":
    arguments = parser().parse_args()
    try:
        raise SystemExit(arguments.func(arguments))
    except OfficeError as error:
        print(f"office-tool: {error}", file=sys.stderr)
        raise SystemExit(2)
